# GetRallied — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=19100
BASE_URL=https://yourdomain.com

# AI — Claude breaks your vision into tasks
ANTHROPIC_KEY=sk-ant-...

# Email — Brevo (optional, but needed for notifications)
BREVO_KEY=xkeysib-...
BREVO_LIST_ID=3
NOTIFY_EMAIL=you@example.com

# Admin dashboard
ADMIN_USER=admin
ADMIN_PASS=your-secure-password
