<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>GetRallied — Organize anything. Together.</title>
<meta name="description" content="Describe your vision. AI breaks it into tasks. People claim roles and show up ready. Free, open source event coordination.">
<meta property="og:title" content="GetRallied — Organize anything. Together.">
<meta property="og:description" content="AI-powered event coordination. Describe your vision, share the link, people claim tasks.">
<meta property="og:type" content="website">
<meta property="og:url" content="https://getrallied.com">
<meta property="og:image" content="https://getrallied.com/logo.png">
<meta property="og:site_name" content="GetRallied">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="GetRallied — Organize anything. Together.">
<meta name="twitter:description" content="AI-powered event coordination. Free and open source.">
<meta name="description" content="Describe your vision. AI breaks it into tasks. People claim roles and show up ready. Free, open source event coordination.">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fff;--surface:#f7f6f4;--border:#e5e2dc;
  --text:#111;--muted:#777;--faint:#bbb;
  --accent:#111;--accent-hover:#333;
  --font:'Inter',sans-serif;
}
body{background:var(--bg);color:var(--text);font-family:var(--font)}
a{color:var(--text)}

/* ── Hero ── */
.hero{padding:80px 24px 60px;text-align:center;max-width:720px;margin:0 auto}
.hero-logo{height:120px;margin-bottom:32px}
h1{font-size:clamp(2rem,5vw,3rem);font-weight:900;letter-spacing:-1.5px;line-height:1.1;margin-bottom:16px}
h1 span{display:block;color:var(--muted);font-weight:600;font-size:clamp(1rem,2.5vw,1.25rem);letter-spacing:-0.3px;margin-top:8px}
.hero-sub{font-size:18px;color:var(--muted);line-height:1.6;max-width:480px;margin:0 auto 36px}
.hero-actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:40px}
.btn-primary{background:var(--accent);color:#fff;padding:14px 32px;font-size:15px;font-weight:700;font-family:var(--font);border:none;text-decoration:none;cursor:pointer;letter-spacing:-0.3px}
.btn-primary:hover{background:var(--accent-hover);color:#fff}
.btn-secondary{background:#fff;color:var(--text);padding:14px 32px;font-size:15px;font-weight:600;font-family:var(--font);border:1.5px solid var(--border);text-decoration:none}
.btn-secondary:hover{border-color:var(--accent)}

/* ── Video ── */
.video-section{max-width:640px;margin:0 auto 80px;padding:0 24px}
.video-wrap{border:2px solid #111;background:#000;position:relative}
.video-wrap video{width:100%;display:block}

/* ── How It Works ── */
.how-section{background:var(--surface);padding:80px 24px;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.how-inner{max-width:860px;margin:0 auto}
.section-title{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--muted);text-align:center;margin-bottom:12px}
.section-heading{font-size:clamp(1.4rem,3vw,2rem);font-weight:800;text-align:center;letter-spacing:-0.5px;margin-bottom:48px}
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.step{text-align:center}
.step-num{width:44px;height:44px;border:2px solid var(--accent);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:800;margin:0 auto 16px}
.step h3{font-size:16px;font-weight:800;margin-bottom:8px;letter-spacing:-0.3px}
.step p{font-size:14px;color:var(--muted);line-height:1.6}
@media(max-width:600px){.steps{grid-template-columns:1fr;gap:40px}}

/* ── Features ── */
.features-section{padding:80px 24px;max-width:860px;margin:0 auto}
.features-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.feature{padding:28px;border:1.5px solid var(--border);border-radius:6px}
.feature-icon{font-size:24px;margin-bottom:12px}
.feature h3{font-size:15px;font-weight:800;margin-bottom:6px;letter-spacing:-0.2px}
.feature p{font-size:14px;color:var(--muted);line-height:1.5}
@media(max-width:600px){.features-grid{grid-template-columns:1fr}}

/* ── Open Source ── */
.oss-section{background:var(--surface);padding:60px 24px;border-top:1px solid var(--border);border-bottom:1px solid var(--border);text-align:center}
.oss-inner{max-width:560px;margin:0 auto}
.oss-badge{display:inline-flex;align-items:center;gap:8px;background:#fff;border:1.5px solid var(--border);padding:8px 16px;font-size:13px;font-weight:700;margin-bottom:20px;color:var(--text);text-decoration:none}
.oss-badge:hover{border-color:var(--accent)}
.oss-badge svg{width:20px;height:20px}
.oss-section h2{font-size:clamp(1.2rem,3vw,1.6rem);font-weight:800;letter-spacing:-0.5px;margin-bottom:12px}
.oss-section p{font-size:15px;color:var(--muted);line-height:1.6;margin-bottom:20px}
.oss-links{display:flex;gap:20px;justify-content:center;font-size:14px;font-weight:600}
.oss-links a{color:var(--muted);text-decoration:none}
.oss-links a:hover{color:var(--text)}

/* ── CTA ── */
.cta-section{padding:80px 24px;text-align:center}
.cta-section h2{font-size:clamp(1.4rem,3vw,2rem);font-weight:800;letter-spacing:-0.5px;margin-bottom:12px}
.cta-section p{font-size:16px;color:var(--muted);margin-bottom:28px}
.templates{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:24px;max-width:600px;margin-left:auto;margin-right:auto}
.tpl-btn{padding:8px 16px;border:1.5px solid var(--border);background:#fff;font-size:13px;font-weight:600;font-family:var(--font);cursor:pointer;color:var(--muted);transition:all .2s}
.tpl-btn:hover{border-color:var(--text);color:var(--text)}
.tpl-btn.active{background:var(--text);color:#fff;border-color:var(--text)}
.create-box{max-width:520px;margin:0 auto;text-align:left}
.create-field{margin-bottom:14px}
.create-field label{display:block;font-size:12px;font-weight:600;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px}
.create-field input,.create-field textarea{width:100%;padding:10px 12px;border:1.5px solid var(--border);font-size:14px;font-family:var(--font);color:var(--text);border-radius:4px;background:#fff}
.create-field input:focus,.create-field textarea:focus{outline:none;border-color:var(--text)}
.create-field input::placeholder,.create-field textarea::placeholder{color:var(--faint)}
.create-field textarea{resize:vertical}
.create-row{display:flex;gap:12px}
.btn-create-submit{width:100%;padding:14px;background:var(--text);color:#fff;border:none;font-size:15px;font-weight:700;font-family:var(--font);cursor:pointer;letter-spacing:-0.3px}
.btn-create-submit:hover{background:var(--accent-hover)}
@media(max-width:500px){.create-row{flex-direction:column;gap:0}}
.create-form{display:flex;gap:0;max-width:440px;margin:0 auto 16px;border:1.5px solid var(--border);background:#fff}
.create-form:focus-within{border-color:#111}
.create-form input{flex:1;border:none;padding:14px 16px;font-size:15px;font-family:var(--font);outline:none;background:transparent;color:var(--text)}
.create-form input::placeholder{color:var(--faint)}
.create-form button{background:#111;color:#fff;border:none;padding:14px 24px;font-size:14px;font-weight:700;font-family:var(--font);cursor:pointer;white-space:nowrap}
.create-form button:hover{background:var(--accent-hover)}
.form-note{font-size:12px;color:var(--faint);text-align:center}

/* ── Footer ── */
footer{border-top:1px solid var(--border);padding:32px 24px;text-align:center}
.footer-inner{max-width:860px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
.footer-links{display:flex;gap:20px;font-size:13px}
.footer-links a{color:var(--muted);text-decoration:none;font-weight:500}
.footer-links a:hover{color:var(--text)}
.footer-copy{font-size:12px;color:var(--faint)}
</style>
</head>
<body>
<%- include("partials/nav", { _navActive: "" }) %>

<!-- Hero -->
<div class="hero">
  <img src="/logo.png" alt="GetRallied" class="hero-logo">
  <h1>Organize anything.<span>AI breaks it down. People show up.</span></h1>
  <p class="hero-sub">Describe what you're trying to pull off. GetRallied turns it into a task board, and people claim roles so everyone knows what they're doing.</p>
  <div class="hero-actions">
    <a href="/signup" class="btn-primary">Create your first event</a>
    <a href="/explore" class="btn-secondary">Browse events</a>
  </div>
</div>

<!-- Video -->
<div class="video-section">
  <div class="video-wrap">
    <video controls preload="metadata" playsinline poster="/getrallied-intro-thumb.jpg">
      <source src="/getrallied-intro.mp4" type="video/mp4">
    </video>
  </div>
</div>

<!-- How It Works -->
<div class="how-section">
  <div class="how-inner">
    <div class="section-title">How it works</div>
    <div class="section-heading">From idea to organized in 60 seconds</div>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Describe your vision</h3>
        <p>Tell us what you're organizing — a beach cleanup, a block party, a fundraiser. Be as specific or vague as you want.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>AI creates the plan</h3>
        <p>We break your vision into concrete tasks with roles, quantities, and categories. Edit anything — add, remove, reorder.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>Share & rally people</h3>
        <p>Send the link. People claim tasks they can handle. Everyone shows up knowing exactly what they're doing.</p>
      </div>
    </div>
  </div>
</div>

<!-- Features -->
<div class="features-section">
  <div class="section-title">Built for real events</div>
  <div class="section-heading" style="text-align:center;margin-bottom:40px">Everything you need, nothing you don't</div>
  <div class="features-grid">
    <div class="feature">
      <div class="feature-icon">🤖</div>
      <h3>AI task breakdown</h3>
      <p>Describe what you need in plain English. Claude turns it into an actionable task list with roles and quantities.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">📋</div>
      <h3>Claim & commit</h3>
      <p>No more "I'll try to make it." People claim specific tasks. You see who's doing what in real time.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">✅</div>
      <h3>Approval controls</h3>
      <p>Auto-approve general tasks. Require approval for leadership roles. You stay in control of who does what.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">📊</div>
      <h3>Progress tracking</h3>
      <p>See fill rates, pending claims, and who signed up — at a glance. Export everything to CSV.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">🔗</div>
      <h3>One link does it all</h3>
      <p>Share a link or QR code. No app downloads, no accounts required for volunteers. Just click and claim.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">🌎</div>
      <h3>Public or private</h3>
      <p>Keep events private with a direct link, or make them discoverable on the Explore page.</p>
    </div>
  </div>
</div>

<!-- Open Source -->
<div class="oss-section">
  <div class="oss-inner">
    <a href="https://github.com/ercsn/get_rallied" target="_blank" class="oss-badge">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      Open Source on GitHub
    </a>
    <h2>Built in the open</h2>
    <p>GetRallied is free and open source. Run it yourself, contribute features, or fork it for your community. No vendor lock-in, no hidden costs.</p>
    <div class="oss-links">
      <a href="https://github.com/ercsn/get_rallied" target="_blank">View source →</a>
      <a href="https://github.com/ercsn/get_rallied/issues" target="_blank">Report an issue →</a>
    </div>
  </div>
</div>

<!-- CTA -->
<div class="cta-section" id="create">
  <h2>Ready to rally?</h2>
  <p>Start organizing in under a minute. Free forever.</p>
  <form class="create-form" action="/notify" method="POST">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
    <input type="email" name="email" placeholder="your@email.com" required>
    <button type="submit">Get started</button>
  </form>
  <p class="form-note">Or <a href="/signup" style="font-weight:600">create an account</a> to start building events now.</p>
</div>

<!-- Footer -->
<footer>
  <div class="footer-inner">
    <div class="footer-links">
      <a href="/explore">Explore</a>
      <a href="/signup">Sign up</a>
      <a href="https://github.com/ercsn/get_rallied" target="_blank">GitHub</a>
    </div>
    <div class="footer-copy">© 2026 GetRallied — Built by <a href="https://ercsn.com" style="color:var(--muted)" target="_blank">ERCSN</a></div>
  </div>
</footer>
</body>
</html>
