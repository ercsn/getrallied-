<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="icon" href="/favicon.ico"><link rel="apple-touch-icon" href="/apple-touch-icon.png">
<title><%= event.title %> — GetRallied</title>
<meta name="description" content="<%= event.vision ? event.vision.substring(0, 155) : event.title + " — Sign up to help" %>">
<!-- Open Graph -->
<meta property="og:title" content="<%= event.title %> — GetRallied">
<meta property="og:description" content="<%= event.vision ? event.vision.substring(0, 200) : "Sign up and claim a role" %>">
<meta property="og:type" content="website">
<meta property="og:url" content="<%= typeof baseUrl !== "undefined" ? baseUrl : "https://getrallied.com" %>/event/<%= event.id %>">
<% if (event.banner_image) { %><meta property="og:image" content="<%= typeof baseUrl !== "undefined" ? baseUrl : "https://getrallied.com" %><%= event.banner_image %>"><% } else { %><meta property="og:image" content="<%= typeof baseUrl !== "undefined" ? baseUrl : "https://getrallied.com" %>/logo.png"><% } %>
<meta property="og:site_name" content="GetRallied">
<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= event.title %>">
<meta name="twitter:description" content="<%= event.vision ? event.vision.substring(0, 200) : "Sign up and claim a role" %>">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fff;
  --surface:#f7f6f4;
  --border:#e5e2dc;
  --border-dark:#ccc;
  --text:#111;
  --muted:#777;
  --faint:#bbb;
  --accent:#111111;
  --accent-hover:#a84f14;
  --green:#111111;
  --green-bg:#f5f5f5;
  --green-border:#ddd;
  --font:'Inter',sans-serif;
}
body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh}
nav{border-bottom:1px solid var(--border);padding:14px 24px;display:flex;align-items:center;justify-content:space-between}
.logo{font-size:16px;font-weight:800;letter-spacing:-0.5px;text-decoration:none;color:var(--text)}
.logo span{color:#111111}

.event-details-wrap{border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.event-details{display:grid;grid-template-columns:1fr 1fr;gap:0;max-width:680px;margin:0 auto}
.detail-col{padding:24px 32px;text-align:left}
.detail-col:first-child{border-right:1px solid var(--border)}
.detail-header{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.detail-icon{font-size:16px}
.detail-heading{font-size:16px;font-weight:800;color:#111}
.detail-sub{font-size:14px;color:#222;line-height:1.6;margin-bottom:2px}
.detail-sub-muted{font-size:13px;color:#888;line-height:1.5}
.detail-link{display:inline-block;margin-top:8px;color:#111;font-weight:700;font-size:13px;text-decoration:underline}
@media(max-width:520px){.event-details{grid-template-columns:1fr}.detail-col:first-child{border-right:none;border-bottom:1px solid var(--border)}}
  .event-banner{width:100%;max-height:340px;object-fit:cover;display:block}
  .org-logo-img{height:44px;margin-bottom:12px;display:block}
  /* Success banner */
.success-bar{background:#fef3ec;border-bottom:1px solid #f5d5ba;padding:12px 24px;text-align:center;font-size:14px;color:#111111;font-weight:600}

/* Hero */
.hero{background:var(--surface);border-bottom:1px solid var(--border);padding:36px 24px}
.hero-inner{max-width:680px;margin:0 auto}
.event-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:#111111;margin-bottom:10px}
h1{font-size:clamp(24px,5vw,38px);font-weight:900;letter-spacing:-0.5px;margin-bottom:12px;line-height:1.15}
.meta{display:flex;flex-wrap:wrap;gap:16px;margin-bottom:20px}
.meta-item{font-size:14px;color:var(--muted);display:flex;align-items:center;gap:5px}
.progress-row{display:flex;align-items:center;gap:12px}
.progress-track{flex:1;height:4px;background:var(--border);border-radius:2px;overflow:hidden;max-width:200px}
.progress-fill{height:4px;background:#111111;border-radius:2px}
.progress-label{font-size:13px;font-weight:600;color:var(--text)}
.progress-sub{font-size:12px;color:var(--muted)}

/* Main */
.main{max-width:680px;margin:0 auto;padding:32px 24px}

/* Vision quote */
.vision{background:var(--surface);border-left:3px solid #111111;padding:14px 18px;margin-bottom:28px;font-size:14px;color:var(--muted);line-height:1.6;font-style:italic}

.section-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--muted);margin-bottom:14px}

/* Task cards */
.tasks{display:flex;flex-direction:column;gap:8px;margin-bottom:36px}
.task-card{border:1px solid var(--border);background:#fff;padding:16px 18px;display:flex;align-items:flex-start;gap:14px}
.task-card:hover{border-color:var(--border-dark)}
.task-card.full{background:var(--surface);opacity:0.7}
.task-cat{font-size:20px;flex-shrink:0;margin-top:1px}
.task-body{flex:1}
.task-title{font-size:15px;font-weight:700;margin-bottom:3px}
.task-desc{font-size:13px;color:var(--muted);line-height:1.5}
.task-right{display:flex;flex-direction:column;align-items:flex-end;gap:7px;flex-shrink:0}
.spots-left{font-size:12px;font-weight:600;color:#111111}
.spots-full{font-size:13px;font-weight:700;color:#111}
.claim-btn{background:#111111;color:#fff;border:none;padding:8px 18px;font-size:13px;font-weight:700;font-family:var(--font);cursor:pointer}
.claim-btn:hover{background:var(--accent-hover)}
.claimed-badge{background:#111;color:#fff;border:1px solid #111;padding:6px 14px;font-size:12px;font-weight:700}
.claimants{display:flex;flex-wrap:wrap;gap:5px;margin-top:8px}
.claimant-pill{background:var(--surface);border:1px solid var(--border);padding:3px 10px;font-size:12px;color:var(--muted)}

/* Share section */
.share-card{border:1px solid var(--border);padding:20px;display:flex;align-items:center;gap:20px;margin-bottom:8px}
.qr-img{width:80px;height:80px;flex-shrink:0;border:1px solid var(--border)}
.share-text h3{font-size:15px;font-weight:700;margin-bottom:4px}
.share-text p{font-size:13px;color:var(--muted);margin-bottom:10px}
.copy-row{display:flex;gap:0;border:1px solid var(--border)}
.copy-row input{flex:1;border:none;padding:8px 12px;font-size:12px;font-family:monospace;outline:none;background:#fff;color:var(--text)}
.social-share{display:flex;gap:8px;margin-top:12px}
.share-btn{display:flex;align-items:center;justify-content:center;width:36px;height:36px;border:1.5px solid var(--border);text-decoration:none;font-size:16px;font-weight:700;color:var(--text);transition:border-color .2s}
.share-btn:hover{border-color:var(--text);background:var(--surface)}
.copy-btn{background:#111111;color:#fff;border:none;padding:8px 14px;font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap}
.copy-btn:hover{background:var(--accent-hover)}

/* Modal */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:100;align-items:center;justify-content:center;padding:20px}
.modal-overlay.open{display:flex}
.modal{background:#fff;border:1px solid var(--border);padding:28px;width:100%;max-width:400px}
.modal h3{font-size:18px;font-weight:800;margin-bottom:4px}
.modal-sub{font-size:13px;color:var(--muted);margin-bottom:22px}
.field{margin-bottom:14px}
label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:5px}
input{width:100%;border:1px solid var(--border);padding:10px 12px;font-size:14px;font-family:var(--font);outline:none;color:var(--text);background:#fff}
input:focus{border-color:#111111}
.modal-btns{display:flex;gap:10px;margin-top:4px}
.btn-primary{flex:1;background:#111111;color:#fff;border:none;padding:12px;font-size:14px;font-weight:700;font-family:var(--font);cursor:pointer}
.btn-primary:hover{background:var(--accent-hover)}
.btn-cancel{background:#fff;color:var(--muted);border:1px solid var(--border);padding:12px 16px;font-size:14px;font-family:var(--font);cursor:pointer}

  /* === B&W Retheme === */
  :root {
    --accent: #111111;
    --accent-hover: #333333;
  }
  .claim-btn, .add-btn, .approve-btn, button[type="submit"] {
    background: #111 !important;
    color: #fff !important;
    border-color: #111 !important;
  }
  .claim-btn:hover, .add-btn:hover, button[type="submit"]:hover {
    background: #333 !important;
    border-color: #333 !important;
  }
  .deny-btn {
    background: #fff !important;
    color: #111 !important;
    border: 1px solid #111 !important;
  }
  .deny-btn:hover { background: #f5f5f5 !important; }
  .trust-toggle.on {
    background: #111 !important;
    color: #fff !important;
    border-color: #111 !important;
  }
  .badge-open { background: #111 !important; color: #fff !important; }
  .success-bar { background: #f5f5f5 !important; border-color: #ddd !important; color: #111 !important; }
  a { color: #111; }
  a:hover { color: #444; }

  </style>
</head>
<body>
<%- include("partials/nav", { _navActive: "" }) %>
<% if (event.banner_image) { %>
<img src="<%= event.banner_image %>" alt="Event banner" class="event-banner">
<% } %>

<% if (claimed) { %>
<div class="success-bar"> You're in — thanks for claiming your piece of this.</div>
<% } %>
<% if (typeof pending !== 'undefined' && pending) { %>
<div class="success-bar" style="background:#fef9ec;border-color:#f5e4ba;color:#92670a">⏳ Your request is pending review. The organizer will confirm your spot.</div>
<% } %>

<div class="hero">
  <div class="hero-inner">
    <div class="event-label">Event</div>
    <% if (event.org_logo) { %><img src="<%= event.org_logo %>" alt="Org logo" class="org-logo-img"><% } %>
    <h1><%= event.title %></h1>
    <div class="meta">
      <% if (event.date) { %><div class="meta-item">📅 <%= event.date %></div><% } %>
      <% if (event.location) { %><div class="meta-item">📍 <%= event.location %></div><% } %>
    </div>
    <%
      const totalNeeded = tasks.filter(t=>t.quantity_needed>0).reduce((s,t)=>s+t.quantity_needed,0);
      const totalClaimed = tasks.filter(t=>t.quantity_needed>0).reduce((s,t)=>s+t.quantity_claimed,0);
      const pct = totalNeeded > 0 ? Math.round((totalClaimed/totalNeeded)*100) : 0;
    %>
    <div class="progress-row">
      <div class="progress-track"><div class="progress-fill" style="width:<%= pct %>%"></div></div>
      <div class="progress-label"><%= totalClaimed %> / <%= totalNeeded %></div>
      <div class="progress-sub">tasks claimed</div>
    </div>
    <% if (typeof peopleCount !== 'undefined' && peopleCount > 0) { %>
    <div style="margin-top:16px;display:flex;align-items:center;gap:8px;justify-content:center">
      <span style="font-size:28px;font-weight:800;color:#111"><%= peopleCount %></span>
      <span style="font-size:14px;color:#777;font-weight:600"><%= peopleCount === 1 ? 'person' : 'people' %> showing up</span>
    </div>
    <% } %>
  </div>
</div>

<% if (event.date || event.event_time || event.location_name || event.location_address) { %>
<div class="event-details-wrap">
<div class="event-details">
  <div class="detail-col">
    <div class="detail-header"><span class="detail-icon">📅</span><span class="detail-heading">Time</span></div>
    <% if (event.date) { %><div class="detail-sub"><strong><%= event.date %></strong></div><% } %>
    <% if (event.event_time) { %><div class="detail-sub"><%= event.event_time %></div><% } %>
  </div>
  <div class="detail-col">
    <div class="detail-header"><span class="detail-icon">📍</span><span class="detail-heading">Location</span></div>
    <% if (event.location_name) { %><div class="detail-sub"><strong><%= event.location_name %></strong></div><% } %>
    <% if (event.location_address) { %><div class="detail-sub-muted"><%- event.location_address.replace(/\n/g,'<br>') %></div><% } %>
    <% if (!event.location_name && event.location) { %><div class="detail-sub"><strong><%= event.location %></strong></div><% } %>
    <% if (event.location_maps_url) { %><a href="<%= event.location_maps_url %>" target="_blank" class="detail-link">Map</a><% } %>
  </div>
</div>
</div>
<% } %>
<div class="main">
  <% if (event.vision) { %>
  <div class="vision">"<%= event.vision %>"</div>
  <% } %>

  <div class="section-label">What we need — claim a piece</div>
  <div class="tasks">
    <% const catEmoji={people:'🙋',skills:'🎯',materials:'📦',logistics:'📋'}; %>
    <% tasks.forEach(task => { %>
    <% const taskClaims = claimsByTask[task.id]||[]; const isUnlimited = task.quantity_needed === 0; const isFull = !isUnlimited && task.quantity_claimed >= task.quantity_needed; const spotsLeft = task.quantity_needed - task.quantity_claimed; %>
    <div class="task-card <%= isFull ? 'full' : '' %>">
      <div class="task-cat"><%= catEmoji[task.category]||'' %></div>
      <div class="task-body">
        <div class="task-title"><%= task.title %></div>
        <% if (task.description) { %><div class="task-desc"><%= task.description %></div><% } %>
        <% if (taskClaims.length > 0) { %>
        <div class="claimants" style="margin-top:8px">
          <% taskClaims.forEach(c => { %><span class="claimant-pill">👤 <%= c.name.split(' ')[0] %></span><% }); %>
        </div>
        <% } %>
      </div>
      <div class="task-right">
        <% if (task.requires_approval) { %><span style="font-size:10px;color:#111111;font-weight:700;margin-bottom:4px;display:block">🔒 Approval required</span><% } %>
        <% if (isFull) { %>
          <span class="spots-full">Full</span>
          <span class="claimed-badge">Claimed</span>
        <% } else { %>
          <% if (isUnlimited) { %><span class="spots-left">Everyone welcome</span><% } else { %><span class="spots-left"><%= spotsLeft %> spot<%= spotsLeft!==1?'s':'' %> open</span><% } %>
          <% if ((pendingByTask[task.id]||0) > 0) { %><span style="font-size:10px;color:#92670a;margin-bottom:3px;display:block">⏳ <%= pendingByTask[task.id] %> pending</span><% } %>
          <button class="claim-btn" data-task-id="<%= task.id %>" data-task-title="<%= task.title.replace(/"/g,'&quot;') %>" onclick="openClaim(this.dataset.taskId,this.dataset.taskTitle)"><%= task.requires_approval ? 'Request this' : "I'll do this" %></button>
        <% } %>
      </div>
    </div>
    <% }); %>
  </div>

  <% if (typeof eventUpdates !== 'undefined' && eventUpdates.length > 0) { %>
  <div class="section-label">📢 Updates from the organizer</div>
  <div style="margin-bottom:24px">
    <% eventUpdates.forEach(u => { %>
    <div style="background:#f7f6f4;border:1px solid #e5e2dc;padding:14px 18px;margin-bottom:8px;border-radius:4px">
      <div style="font-size:14px;color:#111;line-height:1.6;white-space:pre-wrap"><%= u.message %></div>
      <div style="font-size:11px;color:#aaa;margin-top:8px">📌 <%= u.author_name || 'Organizer' %> · <%= new Date(u.created_at + 'Z').toLocaleDateString('en-US', {month:'short',day:'numeric',hour:'numeric',minute:'2-digit'}) %></div>
    </div>
    <% }); %>
  </div>
  <% } %>

  <div class="section-label">Share this event</div>
  <div class="share-card">
    <img class="qr-img" src="<%= qrDataUrl %>" alt="QR Code">
    <div class="share-text">
      <h3>Spread the word</h3>
      <p>Claim a task to get involved. <a href="/signup" style="color:#111;font-weight:600">Create an account</a> to track your claims privately.</p>
      <div class="copy-row">
        <input type="text" id="share-url" readonly value="<%= eventUrl %>">
        <button class="copy-btn" onclick="navigator.clipboard.writeText(document.getElementById('share-url').value);this.textContent='Copied!'">Copy</button>
      </div>
      <div class="social-share">
        <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(event.title + ' — Sign up and help out!') %>&url=<%= encodeURIComponent(eventUrl) %>" target="_blank" rel="noopener" class="share-btn" title="Share on X/Twitter">𝕏</a>
        <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(eventUrl) %>" target="_blank" rel="noopener" class="share-btn" title="Share on Facebook">f</a>
        <a href="mailto:?subject=<%= encodeURIComponent(event.title + ' — GetRallied') %>&body=<%= encodeURIComponent('Check out this event and sign up to help:\n\n' + eventUrl) %>" class="share-btn" title="Share via email">✉</a>
        <a href="sms:?body=<%= encodeURIComponent(event.title + ' — sign up to help: ' + eventUrl) %>" class="share-btn" title="Share via text">💬</a>
      </div>
    </div>
  </div>
</div>

<!-- Claim Modal -->
<div class="modal-overlay" id="claim-modal">
  <div class="modal">
    <h3>Claim: <span id="modal-task-title"></span></h3>
    <div class="modal-sub" id="modal-sub">Let the organizer know who you are.</div>
    <form method="POST" id="claim-form">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
      <div class="field"><label>Your name *</label><input type="text" name="name" required placeholder="Full name" value="<%= account && account.name ? account.name : '' %>"></div>
      <div class="field"><label>Email</label><input type="email" name="email" placeholder="For follow-up" value="<%= account && account.email ? account.email : '' %>"></div>
      <div class="field"><label>Phone</label><input type="text" name="phone" placeholder="Optional"></div>
      <% if (!account) { %>
      <div style="background:#f7f6f4;border:1px solid #e5e2dc;padding:10px 14px;margin-bottom:12px;font-size:13px;color:#555;line-height:1.5">
        🔒 <a href="/signup?next=<%= encodeURIComponent('/event/' + event.id) %>" style="color:#111;font-weight:700">Create an account</a> or <a href="/signin?next=<%= encodeURIComponent('/event/' + event.id) %>" style="color:#111;font-weight:700">sign in</a> to track your claims privately.
      </div>
      <% } %>
      <div class="modal-btns">
        <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn-primary">Claim it</button>
      </div>
    </form>
  </div>
</div>
<script>
function openClaim(taskId,taskTitle){
  document.getElementById('modal-task-title').textContent=taskTitle;
  document.getElementById('claim-form').action='/claim/'+taskId;
  document.getElementById('claim-modal').classList.add('open');
}
function closeModal(){document.getElementById('claim-modal').classList.remove('open')}
document.getElementById('claim-modal').addEventListener('click',function(e){if(e.target===this)closeModal()});
</script>
<% if (event) { %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "<%= event.title.replace(/"/g, '\\"') %>",
  "description": "<%= (event.vision || '').replace(/"/g, '\\"').replace(/\n/g, ' ').substring(0, 500) %>",
  <% if (event.date) { %>"startDate": "<%= event.date %>",<% } %>
  <% if (event.location_name || event.location) { %>"location": {
    "@type": "Place",
    "name": "<%= (event.location_name || event.location || '').replace(/"/g, '\\"') %>"<% if (event.location_address) { %>,
    "address": "<%= event.location_address.replace(/"/g, '\\"') %>"<% } %>
  },<% } %>
  "organizer": {
    "@type": "Person",
    "name": "<%= (event.organizer_name || 'Event Organizer').replace(/"/g, '\\"') %>"
  },
  "url": "<%= typeof baseUrl !== 'undefined' ? baseUrl : 'https://getrallied.com' %>/event/<%= event.id %>",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode"<% if (event.banner_image) { %>,
  "image": "<%= typeof baseUrl !== 'undefined' ? baseUrl : 'https://getrallied.com' %><%= event.banner_image %>"<% } %>
}
</script>
<% } %>
</body>
</html>
