<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="icon" href="/favicon.ico"><link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <title>Account Settings — GetRallied</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#fff;color:#111;min-height:100vh}
    .container{max-width:560px;margin:0 auto;padding:40px 24px}
    h1{font-size:24px;font-weight:800;letter-spacing:-0.5px;margin-bottom:6px}
    .sub{color:#777;font-size:15px;margin-bottom:32px}
    .success{background:#f0fdf4;color:#166534;padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:20px;border:1px solid #bbf7d0}
    .error-msg{background:#fef2f2;color:#b91c1c;padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:20px;border:1px solid #fecaca}
    .section{border:1.5px solid #e5e2dc;border-radius:6px;padding:28px;margin-bottom:20px}
    .section-title{font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#777;margin-bottom:20px}
    label{display:block;font-size:12px;font-weight:600;color:#777;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px}
    input[type=text],input[type=email],input[type=password]{width:100%;padding:10px 12px;border-radius:4px;border:1.5px solid #e5e2dc;background:#fff;color:#111;font-size:15px;font-family:inherit;margin-bottom:14px}
    input:focus{outline:none;border-color:#111}
    input::placeholder{color:#bbb}
    .btn{padding:10px 20px;border:none;background:#111;color:#fff;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;letter-spacing:-0.2px}
    .btn:hover{background:#333}
    .btn-outline{padding:10px 20px;border:1.5px solid #e5e2dc;background:#fff;color:#777;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit}
    .btn-outline:hover{border-color:#111;color:#111}
    .btn-row{display:flex;gap:10px;align-items:center}
    .photo-section{display:flex;align-items:center;gap:20px;margin-bottom:16px}
    .avatar{width:72px;height:72px;border-radius:50%;background:#f7f6f4;border:1.5px solid #e5e2dc;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:800;color:#777;overflow:hidden;flex-shrink:0}
    .avatar img{width:100%;height:100%;object-fit:cover}
    .photo-actions{display:flex;flex-direction:column;gap:6px}
    .file-label{display:inline-block;padding:8px 16px;background:#fff;border:1.5px solid #e5e2dc;font-size:12px;font-weight:600;cursor:pointer;color:#777}
    .file-label:hover{border-color:#111;color:#111}
    .file-label input{display:none}
    .remove-link{font-size:12px;color:#b91c1c;text-decoration:none;cursor:pointer;background:none;border:none;font-family:inherit;padding:0}
    .remove-link:hover{text-decoration:underline}
    .danger-zone{border-color:#fecaca}
    .danger-zone .section-title{color:#b91c1c}
    .member-since{font-size:12px;color:#aaa;text-align:center;margin-top:8px}
  </style>
</head>
<body>
  <%- include('partials/nav', { _navActive: 'account' }) %>
  <div class="container">
    <h1>Account Settings</h1>
    <p class="sub">Manage your profile, email, and password.</p>

    <% if (saved) { %><div class="success">✅ Changes saved.</div><% } %>
    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

    <!-- Profile Photo -->
    <div class="section">
      <div class="section-title">Profile Photo</div>
      <div class="photo-section">
        <div class="avatar">
          <% if (account.profile_pic) { %>
            <img src="<%= account.profile_pic %>" alt="Profile">
          <% } else { %>
            <%= (account.name || account.email).charAt(0).toUpperCase() %>
          <% } %>
        </div>
        <div class="photo-actions">
          <form method="POST" action="/account/photo" enctype="multipart/form-data" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
            <label class="file-label">
              📷 Upload photo
              <input type="file" name="photo" accept="image/*" onchange="this.form.submit()">
            </label>
          </form>
          <% if (account.profile_pic) { %>
            <form method="POST" action="/account/photo/remove" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
              <button type="submit" class="remove-link">Remove photo</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Profile Info -->
    <div class="section">
      <div class="section-title">Profile</div>
      <form method="POST" action="/account">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
        <label>Name</label>
        <input type="text" name="name" value="<%= account.name || '' %>" placeholder="Your name">
        <label>Email</label>
        <input type="email" name="email" value="<%= account.email %>" required>
        <button type="submit" class="btn">Save Changes</button>
      </form>
    </div>

    <!-- Change Password -->
    <div class="section">
      <div class="section-title">Change Password</div>
      <form method="POST" action="/account/password">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
        <label>Current Password</label>
        <input type="password" name="current_password" required>
        <label>New Password</label>
        <input type="password" name="new_password" placeholder="At least 6 characters" minlength="6" required>
        <button type="submit" class="btn">Update Password</button>
      </form>
    </div>

    <p class="member-since">Member since <%= new Date(account.created_at).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></p>

    <!-- Delete Account -->
    <div class="section" style="border-color:#fecaca;margin-top:32px">
      <div class="section-title" style="color:#b91c1c">⚠️ Delete Account</div>
      <p style="color:#777;font-size:13px;margin-bottom:16px;line-height:1.5">Permanently delete your account and all your data — events, claims, uploads. This cannot be undone.</p>
      <form method="POST" action="/account/delete" onsubmit="return confirm('This will permanently delete your account, all your events, claims, and data. Are you sure?')">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <label>Type your email to confirm: <strong><%= account.email %></strong></label>
        <input type="email" name="confirm_email" placeholder="<%= account.email %>" required style="margin-bottom:12px">
        <button type="submit" style="background:#fff;color:#b91c1c;border:1.5px solid #fecaca;padding:10px 18px;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;width:100%">Delete my account permanently</button>
      </form>
    </div>
  </div>
</body>
</html>
