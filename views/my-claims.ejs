<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="icon" href="/favicon.ico"><link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <title>My Claims — GetRallied</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#fff;color:#111;min-height:100vh}
    .container{max-width:700px;margin:0 auto;padding:40px 24px}
    h1{font-size:24px;font-weight:800;letter-spacing:-0.5px;margin-bottom:6px}
    .sub{color:#777;font-size:15px;margin-bottom:28px}
    .claim-card{border:1.5px solid #e5e2dc;border-radius:6px;padding:20px;margin-bottom:12px;transition:border-color .2s}
    .claim-card:hover{border-color:#111}
    .claim-event{display:flex;align-items:center;gap:12px;margin-bottom:12px}
    .claim-event-banner{width:48px;height:48px;border-radius:4px;background:#f7f6f4;object-fit:cover;flex-shrink:0}
    .claim-event-info h3{font-size:15px;font-weight:800;letter-spacing:-0.2px;margin-bottom:2px}
    .claim-event-info h3 a{color:inherit;text-decoration:none}
    .claim-event-info h3 a:hover{text-decoration:underline}
    .claim-event-info .meta{font-size:12px;color:#777}
    .claim-task{background:#f7f6f4;padding:10px 14px;border-radius:4px;display:flex;align-items:center;justify-content:space-between}
    .claim-task-name{font-size:14px;font-weight:700}
    .claim-status{font-size:11px;font-weight:700;padding:3px 8px;border-radius:3px}
    .status-approved{background:#f0fdf4;color:#166534}
    .status-pending{background:#fef3c7;color:#92400e}
    .empty{text-align:center;padding:48px 20px;color:#aaa}
    .empty h2{font-size:18px;color:#777;margin-bottom:8px;font-weight:700}
    .count{font-size:14px;color:#777;margin-bottom:20px}
    .privacy-note{background:#f7f6f4;border:1px solid #e5e2dc;padding:12px 16px;font-size:13px;color:#777;margin-bottom:24px;border-radius:4px}
    .privacy-note strong{color:#111}
  </style>
</head>
<body>
  <%- include('partials/nav', { _navActive: 'my-claims' }) %>
  <div class="container">
    <h1>My Claims</h1>
    <p class="sub">Everything you've signed up for across all events.</p>

    <div class="privacy-note">🔒 <strong>Your claims are private.</strong> Only you can see this page when signed in.</div>

    <% if (claims.length === 0) { %>
      <div class="empty">
        <h2>No claims yet</h2>
        <p>You haven't claimed any tasks yet. <a href="/explore" style="color:#111;font-weight:600">Browse events</a> to find something to join.</p>
      </div>
    <% } else { %>
      <p class="count">📋 <%= claims.length %> claim<%= claims.length !== 1 ? 's' : '' %></p>
      <% claims.forEach(c => { %>
        <div class="claim-card">
          <div class="claim-event">
            <% if (c.banner_image) { %>
              <img src="<%= c.banner_image %>" class="claim-event-banner">
            <% } else { %>
              <div class="claim-event-banner" style="display:flex;align-items:center;justify-content:center;font-size:20px;color:#bbb">📣</div>
            <% } %>
            <div class="claim-event-info">
              <h3><a href="/event/<%= c.event_id %>"><%= c.event_title %></a></h3>
              <div class="meta">
                <%= [c.event_date, c.event_time].filter(Boolean).join(' · ') || 'Date TBD' %>
                <% if (c.location_name || c.event_location) { %> · 📍 <%= c.location_name || c.event_location %><% } %>
              </div>
            </div>
          </div>
          <div class="claim-task">
            <span class="claim-task-name"><%= c.task_title %></span>
            <span class="claim-status status-<%= c.status %>"><%= c.status === 'approved' ? '✅ Confirmed' : '⏳ Pending' %></span>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</body>
</html>
