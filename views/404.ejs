<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Page not found — GetRallied</title>
  <link rel="icon" href="/favicon.ico">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; 
      background: #fff; 
      color: #111; 
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    .content {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px 20px;
      text-align: center;
    }
    h1 { 
      font-size: 72px; 
      font-weight: 900; 
      color: #111; 
      margin-bottom: 12px;
    }
    h2 {
      font-size: 24px;
      font-weight: 600;
      color: #555;
      margin-bottom: 24px;
    }
    p { 
      color: #777; 
      font-size: 16px; 
      line-height: 1.6;
      margin-bottom: 32px;
      max-width: 480px;
    }
    .links {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .btn {
      display: inline-block;
      padding: 12px 24px;
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
      border-radius: 4px;
      transition: all 0.2s;
    }
    .btn-primary {
      background: #111;
      color: #fff;
    }
    .btn-primary:hover {
      background: #333;
    }
    .btn-secondary {
      background: #fff;
      color: #111;
      border: 1.5px solid #e5e2dc;
    }
    .btn-secondary:hover {
      background: #f5f5f5;
    }
  </style>
</head>
<body>
  <%- include("partials/nav", { _navActive: "", account: typeof account !== "undefined" ? account : null }) %>
  
  <div class="content">
    <h1>404</h1>
    <h2>Page not found</h2>
    <p>This event may have moved, or the page you're looking for doesn't exist.</p>
    <div class="links">
      <a href="/" class="btn btn-primary">← Back to home</a>
      <a href="/explore" class="btn btn-secondary">Browse events</a>
    </div>
  </div>
</body>
</html>
