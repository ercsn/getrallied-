<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Sign In — GetRallied</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}body{font-family:'Inter',sans-serif;background:#111;color:#fff;min-height:100vh;display:flex;align-items:center;justify-content:center}
    .card{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:12px;padding:40px;max-width:420px;width:100%}
    .logo{display:block;margin:0 auto 24px;height:44px}
    h1{font-size:24px;font-weight:800;text-align:center;margin-bottom:8px}
    .sub{color:#888;text-align:center;margin-bottom:24px;font-size:14px}
    .error{background:#3c1a1a;color:#ff5f5f;padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:16px}
    label{display:block;font-size:13px;font-weight:600;color:#aaa;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px}
    input[type=email],input[type=password]{width:100%;padding:12px;border-radius:6px;border:1px solid #333;background:#111;color:#fff;font-size:16px;font-family:inherit;margin-bottom:16px}
    input:focus{outline:none;border-color:#C8621A}
    .btn{width:100%;padding:14px;border:none;border-radius:8px;background:#C8621A;color:#fff;font-size:16px;font-weight:700;cursor:pointer;font-family:inherit}
    .btn:hover{background:#b55618}
    .alt{text-align:center;margin-top:20px;font-size:14px;color:#888}
    .alt a{color:#C8621A;text-decoration:none;font-weight:600}
    .magic{text-align:center;margin-top:12px;font-size:13px;color:#666}
    .magic a{color:#888;text-decoration:none}
  </style>
</head>
<body>
  <div class="card">
    <a href="/"><img src="/logo.png" alt="GetRallied" class="logo"></a>
    <h1>Welcome back</h1>
    <p class="sub">Sign in to manage your events.</p>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="POST" action="/signin">
      <input type="hidden" name="next" value="<%= next %>">
      <label>Email</label>
      <input type="email" name="email" placeholder="you@example.com" required>
      <label>Password</label>
      <input type="password" name="password" required>
      <button type="submit" class="btn">Sign In</button>
    </form>
    <p class="alt">Don't have an account? <a href="/signup">Sign up</a></p>
    <p class="magic"><a href="/login">Or use a magic link →</a></p>
  </div>
</body>
</html>
