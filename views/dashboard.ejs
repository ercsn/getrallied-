<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Dashboard — GetRallied</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}body{font-family:'Inter',sans-serif;background:#111;color:#fff;min-height:100vh}
    nav{display:flex;align-items:center;padding:16px 24px;border-bottom:1px solid #222}
    nav img{height:32px}
    nav .spacer{flex:1}
    nav a{color:#888;text-decoration:none;font-size:14px;margin-left:20px;font-weight:600}
    nav a:hover{color:#fff}
    nav .name{color:#C8621A;font-weight:700;font-size:14px;margin-left:20px}
    .container{max-width:900px;margin:0 auto;padding:32px 24px}
    h1{font-size:28px;font-weight:800;margin-bottom:8px}
    .sub{color:#888;font-size:15px;margin-bottom:32px}
    .btn-create{display:inline-block;background:#C8621A;color:#fff;padding:12px 28px;border-radius:8px;font-weight:700;font-size:15px;text-decoration:none;margin-bottom:32px}
    .btn-create:hover{background:#b55618}
    .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
    .event-card{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:10px;overflow:hidden;transition:border-color .2s}
    .event-card:hover{border-color:#C8621A}
    .event-card a{text-decoration:none;color:inherit;display:block}
    .card-banner{width:100%;height:120px;object-fit:cover;background:#222}
    .card-body{padding:16px}
    .card-title{font-size:16px;font-weight:800;margin-bottom:6px}
    .card-meta{font-size:12px;color:#888;margin-bottom:12px}
    .card-stats{display:flex;gap:16px;font-size:12px;color:#aaa}
    .card-stats .stat{display:flex;align-items:center;gap:4px}
    .progress-bar{width:100%;height:4px;background:#2a2a2a;border-radius:2px;margin-top:10px;overflow:hidden}
    .progress-fill{height:100%;background:#C8621A;border-radius:2px;transition:width .3s}
    .empty{text-align:center;padding:60px 20px;color:#666}
    .empty h2{font-size:20px;margin-bottom:8px;color:#888}
    .badge{display:inline-block;background:#3c2a1a;color:#C8621A;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700;margin-left:8px}
    .badge-private{background:#2a2a2a;color:#888}
  </style>
</head>
<body>
  <nav>
    <a href="/"><img src="/logo.png" alt="GetRallied"></a>
    <div class="spacer"></div>
    <a href="/explore">Explore</a>
    <a href="/dashboard">Dashboard</a>
    <span class="name"><%= account.name || account.email %></span>
    <a href="/signout">Sign out</a>
  </nav>
  <div class="container">
    <h1>Your Events</h1>
    <p class="sub">Manage your events and see who's rallying.</p>
    <a href="/#create" class="btn-create">+ Create New Event</a>

    <% if (events.length === 0) { %>
      <div class="empty">
        <h2>No events yet</h2>
        <p>Create your first event and start rallying people.</p>
      </div>
    <% } else { %>
      <div class="grid">
        <% events.forEach(e => { %>
          <div class="event-card">
            <a href="/organizer/<%= e.organizer_token %>">
              <% if (e.banner_image) { %>
                <img src="<%= e.banner_image %>" class="card-banner">
              <% } else { %>
                <div class="card-banner" style="display:flex;align-items:center;justify-content:center;font-size:32px">📣</div>
              <% } %>
              <div class="card-body">
                <div class="card-title">
                  <%= e.title %>
                  <% if (e.is_private) { %><span class="badge badge-private">🔒 Private</span><% } %>
                  <% if (e.pendingCount > 0) { %><span class="badge"><%= e.pendingCount %> pending</span><% } %>
                </div>
                <div class="card-meta">
                  <%= [e.date, e.event_time].filter(Boolean).join(' · ') || 'Date TBD' %> · <%= e.location || 'Location TBD' %>
                </div>
                <div class="card-stats">
                  <div class="stat">📋 <%= e.taskCount %> tasks</div>
                  <div class="stat">🙋 <%= e.claimCount %> people</div>
                  <div class="stat"><%= e.totalNeeded > 0 ? Math.round(e.totalClaimed / e.totalNeeded * 100) : 0 %>% filled</div>
                </div>
                <div class="progress-bar">
                  <div class="progress-fill" style="width:<%= e.totalNeeded > 0 ? Math.min(100, Math.round(e.totalClaimed / e.totalNeeded * 100)) : 0 %>%"></div>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
